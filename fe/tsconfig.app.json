{
  "compilerOptions": {
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.app.tsbuildinfo",
    "target": "es2023",
    "lib": ["ES2023", "DOM"],
    "module": "esnext",
    "types": ["vite/client"],
    "skipLibCheck": true,

    /* Bundler mode */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "moduleDetection": "force",
    "noEmit": true,
    "jsx": "react-jsx",

    /* Linting */
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "erasableSyntaxOnly": true,
    "noFallthroughCasesInSwitch": true
  },
  "include": [
    "src/main.tsx",
    "src/Route.tsx",
    "src/rootRoute.tsx",
    "src/config/**/*.ts",
    "src/lib/**/*.ts",
    "src/apps/**/*.ts",
    "src/apps/**/*.tsx",
    "src/shared/constants/common.ts",
    "src/shared/constants/index.ts",
    "src/shared/constants/permissionUser.ts",
    "src/shared/types/response.type.ts",
    "src/shared/utils/tokenManager.ts"
  ]
}
